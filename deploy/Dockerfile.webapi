FROM golang:1.26.5-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /distkv-webapi ./cmd/distkv-webapi

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=build /distkv-webapi /usr/local/bin/distkv-webapi
EXPOSE 8080
ENTRYPOINT ["distkv-webapi"]
